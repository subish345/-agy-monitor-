#!/usr/bin/env python3
"""
AGY Download Runner — Registers a download, launches the dashboard terminal
if needed, runs the download command, and manages the lifecycle of the active registry.
Also writes completed/failed jobs to the persistent download history.

Usage:
  agy-run-dl --app "App Name" --desc "Description" --source "Source Repo" --type "flatpak|apt|pip|generic" -- <command>
"""

import sys
import os
import json
import uuid
import time
import re
import subprocess
import argparse
from datetime import datetime

ACTIVE_DIR = os.path.expanduser("~/Documents/agy-agent/downloads/active")
LOGS_DIR = os.path.expanduser("~/Documents/agy-agent/logs")
PID_FILE = os.path.expanduser("~/Documents/agy-agent/downloads/monitor.pid")
HISTORY_FILE = os.path.expanduser("~/Documents/agy-agent/downloads/history.json")


def is_monitor_running():
    """Verify if the agy-monitor process is active using the PID file."""
    if os.path.exists(PID_FILE):
        try:
            with open(PID_FILE, 'r') as f:
                pid = int(f.read().strip())
            os.kill(pid, 0)  # checks if PID is active
            return True
        except (ValueError, OSError):
            pass
    return False


def launch_monitor():
    """Start agy-monitor in a new desktop terminal window if it isn't running."""
    if is_monitor_running():
        return

    # Check for terminal emulators
    cmd = [
        "gnome-terminal", "--tab", "--", "bash", "-c",
        "python3 ~/Documents/agy-agent/bin/agy-monitor.py; read"
    ]
    try:
        subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    except Exception:
        # Fallback to x-terminal-emulator
        try:
            subprocess.Popen([
                "x-terminal-emulator", "-e", "bash", "-c",
                "python3 ~/Documents/agy-agent/bin/agy-monitor.py; read"
            ], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
        except Exception as e:
            print(f"Error launching terminal window: {e}", file=sys.stderr)


def format_time(seconds):
    if seconds <= 0:
        return "--"
    if seconds > 3600:
        return f"{int(seconds // 3600)}h {int((seconds % 3600) // 60)}m"
    return f"{int(seconds // 60)}m {int(seconds % 60)}s"


def main():
    if '--' not in sys.argv:
        print("Usage: agy-run-dl [options] -- <command>", file=sys.stderr)
        print("Options: --app <name> --desc <desc> --source <source> --type <type>", file=sys.stderr)
        sys.exit(1)

    idx = sys.argv.index('--')
    opt_args = sys.argv[1:idx]
    cmd_args = sys.argv[idx+1:]

    if not cmd_args:
        print("No command specified after '--'", file=sys.stderr)
        sys.exit(1)

    parser = argparse.ArgumentParser(description="AGY Download Runner")
    parser.add_argument("--app", required=True, help="App Name")
    parser.add_argument("--desc", default="No description", help="App Description")
    parser.add_argument("--source", default="Unknown Source", help="Source Repo / URL")
    parser.add_argument("--type", choices=["apt", "pip", "flatpak", "generic"], default="generic", help="Parser Type")
    parser.add_argument("--log", help="Custom log file path")

    args = parser.parse_args(opt_args)

    os.makedirs(ACTIVE_DIR, exist_ok=True)
    os.makedirs(LOGS_DIR, exist_ok=True)

    task_id = str(uuid.uuid4())[:8]
    log_file = args.log or os.path.join(LOGS_DIR, f"task_{task_id}.log")

    registry_data = {
        "task_id": task_id,
        "app_name": args.app,
        "description": args.desc,
        "source": args.source,
        "type": args.type,
        "log_file": log_file,
        "started_at": time.time(),
        "linger": 0
    }
    registry_file = os.path.join(ACTIVE_DIR, f"{task_id}.json")
    with open(registry_file, 'w') as f:
        json.dump(registry_data, f, indent=2)

    with open(log_file, 'w') as f:
        f.write(f"=== Starting Download Task for {args.app} ===\n")
        f.write(f"Command: {' '.join(cmd_args)}\n\n")

    launch_monitor()

    print(f"⚡ Starting task: {args.app} (ID: {task_id})")
    print(f"📝 Logging to: {log_file}")
    
    exit_code = -1
    try:
        with open(log_file, 'a') as lf:
            process = subprocess.Popen(
                cmd_args,
                stdout=lf,
                stderr=lf,
                text=True,
                bufsize=1
            )
            process.wait()
            
        exit_code = process.returncode
        if exit_code == 0:
            print(f"✓ Task completed successfully: {args.app}")
        else:
            print(f"✗ Task failed with exit code {exit_code}: {args.app}")
            
    except Exception as e:
        with open(log_file, 'a') as lf:
            lf.write(f"\n[Runner Error]: {e}\n")
        print(f"✗ Runner encountered error: {e}", file=sys.stderr)
        
    finally:
        # Save to history
        try:
            history = []
            if os.path.exists(HISTORY_FILE):
                with open(HISTORY_FILE, 'r') as hf:
                    history = json.load(hf)
            
            # Simple size detection from log file
            size_str = "--"
            if os.path.exists(log_file):
                with open(log_file, 'r', errors='ignore') as lf:
                    log_content = lf.read()
                # Find size patterns like "96.3 MB" or "1024 kB" or "Downloaded: 50MB"
                size_matches = re.findall(r'(\d+(?:\.\d+)?\s*(?:[kMG]B|MB|KB|GB))', log_content)
                if size_matches:
                    # Choose the largest size pattern matching total size in download
                    size_str = size_matches[-1]

            elapsed_sec = time.time() - registry_data["started_at"]
            history_entry = {
                "app_name": args.app,
                "source": args.source,
                "type": args.type,
                "started_at": datetime.fromtimestamp(registry_data["started_at"]).strftime("%Y-%m-%d %H:%M:%S"),
                "status": "complete" if exit_code == 0 else "failed",
                "size": size_str,
                "elapsed": format_time(elapsed_sec)
            }
            history.append(history_entry)
            history = history[-50:]  # Limit to 50 records
            
            with open(HISTORY_FILE, 'w') as hf:
                json.dump(history, hf, indent=2)
        except Exception as he:
            print(f"Error saving download history: {he}", file=sys.stderr)

        # Give monitor 10 seconds to read completion status, then clean up
        time.sleep(10)
        if os.path.exists(registry_file):
            try:
                os.remove(registry_file)
            except Exception:
                pass


if __name__ == "__main__":
    main()
